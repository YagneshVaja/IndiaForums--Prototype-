{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node docs/tracking/update-progress.js 2>/dev/null || true",
            "timeout": 15,
            "async": true,
            "statusMessage": "Updating mobile progress tracker..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph status",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph detect-changes --brief",
            "if": "Bash(git commit*)",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
