{
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",

    "allow": [
      "Read(**)",

      "Edit(src/**)",
      "Edit(public/**)",
      "Edit(*.json)",
      "Edit(*.js)",
      "Edit(*.ts)",
      "Edit(*.jsx)",
      "Edit(*.tsx)",
      "Edit(*.css)",
      "Edit(*.md)",
      "Edit(*.html)",
      "Edit(.env.example)",
      "Edit(vite.config.*)",
      "Edit(tailwind.config.*)",
      "Edit(postcss.config.*)",
      "Edit(tsconfig.*)",
      "Edit(.eslintrc.*)",
      "Edit(.prettierrc)",
      "Edit(.gitignore)",

      "MultiEdit(src/**)",
      "MultiEdit(public/**)",

      "Glob",
      "Grep",
      "Task",

      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npm create *)",
      "Bash(npm list *)",
      "Bash(npm outdated *)",
      "Bash(npx tailwindcss *)",
      "Bash(npx vite *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",

      "Bash(node *)",
      "Bash(node --version)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git remote -v)",

      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(find src *)",
      "Bash(find . *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(cp *)",
      "Bash(mv src/* src/*)",
      "Bash(touch *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(* --version)",
      "Bash(* --help)"
    ],

    "ask": [
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git clone *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "WebFetch(*)",
      "WebSearch"
    ],

    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.cert)",
      "Read(**/secrets/**)",
      "Read(**/.aws/**)",
      "Read(**/node_modules/**)",

      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Edit(.env.*)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(**/secrets/**)",

      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(npm publish *)",
      "Bash(vercel *)",
      "Bash(netlify *)",
      "Bash(firebase deploy *)",
      "Bash(gh release *)",
      "Bash(gh auth *)",
      "Bash(git push --force*)",
      "Bash(git branch -D *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(crontab *)",
      "Bash(export *)",
      "Bash(source *)",
      "Bash(eval *)",
      "Bash(exec *)"
    ]
  }
}
